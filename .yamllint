---
extends: default

ignore:
  - helm/*/templates/**

rules:
  document-start: enable
  document-end: disable
  line-length:
    max: 120
    level: warning
  indentation:
    spaces: 2
  truthy:
    level: error
  quoted-strings:
    required: only-when-needed
  anchors:
    forbid-undeclared-aliases: true
    forbid-duplicated-anchors: true
    forbid-unused-anchors: true
  comments:
    min-spaces-from-content: 1
...
